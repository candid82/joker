(require 'joker.http)
(require 'joker.os)
(require 'joker.string)
(require 'joker.time)

(def addr "127.0.0.1:18291")
(def base-url (str "http://" addr))
(def events (chan 10))
(def bad-events (chan 1))
(def close-info (atom nil))
(def error-close-info (atom nil))
(def short-delay (* 50 joker.time/millisecond))

(defn handler
  [req]
  (case (:uri req)
    "/ready" {:status 200 :body "ready"}
    "/events" {:status 200
               :sse events
               :on-close #(reset! close-info %)}
    "/bad-events" {:sse bad-events
                   :on-close #(reset! error-close-info %)}
    {:status 404 :body "missing"}))

(defn wait-ready
  []
  (loop [attempts 20]
    (let [ready? (try
                   (= "ready" (:body (joker.http/send {:url (str base-url "/ready")})))
                   (catch Error e
                     false))]
      (cond
        ready? true
        (zero? attempts) false
        :else (do
                (joker.time/sleep short-delay)
                (recur (dec attempts)))))))

(defn loopback-unavailable?
  [e]
  (let [msg (str e)]
    (or (joker.string/includes? msg "operation not permitted")
        (joker.string/includes? msg "permission denied"))))

(def server (go (joker.http/start-server addr handler)))

(when-not (wait-ready)
  (try
    (<! server)
    (throw (ex-info "HTTP SSE test server did not start" {}))
    (catch Error e
      (if (loopback-unavailable? e)
        (do
          (println "SKIP: loopback networking unavailable")
          (joker.os/exit 0))
        (throw e)))))

(go
  (joker.time/sleep short-delay)
  (>! events "hello")
  (>! events {:event "note"
              :id "42"
              :retry 1500
              :data "line 1\nline 2"})
  (>! events {:comment "done"})
  (close! events))

(let [res (joker.http/send {:url (str base-url "/events")})]
  (println (:status res))
  (println (first (get-in res [:headers "Content-Type"])))
  (print (:body res))
  (println (:reason @close-info)))

(go (>! bad-events 42))

(let [res (joker.http/send {:url (str base-url "/bad-events")})]
  (println (:status res))
  (println (:body res))
  (println (:reason @error-close-info))
  (println (instance? Error (:error @error-close-info))))
