(ns joker.test-joker.time
  (:require [joker.test :refer [deftest is]]
            [joker.time :as time]))

(deftest parse-in-timezone
  (let [t (time/parse-in-timezone "2006-01-02T15:04" "2026-04-06T11:00" "Europe/Rome")]
    (is (= "2026-04-06T11:00:00+02:00" (time/format t time/rfc3339)))
    (is (= "2026-04-06T09:00:00Z" (time/format (time/in-timezone t "UTC") time/rfc3339)))))
